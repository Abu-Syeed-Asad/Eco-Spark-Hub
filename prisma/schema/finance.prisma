model FinanceLog {
  id String @id @default(uuid())

  paymentId String?
  amount    Float   @default(0)

  accountType   ACCOUNT_TYPE   @default(USER)
  financeSource FINANCE_SOURCE @default(DIPOSIT)

  userId  String?
  ownerId String?

  paymentGatewayData Payment? @relation(fields: [paymentId], references: [id])

  user User? @relation("UserFinanceLogs", fields: [userId], references: [id])

  owner User? @relation("OwnerFinanceLogs", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
